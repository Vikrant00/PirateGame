{
    "version": "2.0.0",
    "tasks": [

        // ── GIT ──────────────────────────────────────────────
        {
            "label": "Git: Save & Push (Add + Commit + Push)",
            "type": "shell",
            "command": "git add . && git commit -m \"${input:commitMessage}\" && git push",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Git: Pull Latest",
            "type": "shell",
            "command": "git pull",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Git: Status (What have I changed?)",
            "type": "shell",
            "command": "git status && echo '' && echo '--- LFS Status ---' && git lfs status",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },

        // ── BUILD ─────────────────────────────────────────────
        {
            "label": "UE: Build Editor",
            "type": "shell",
            "command": ".\\Scripts\\BuildEditor.bat",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "UE: Generate Project Files (.sln)",
            "type": "shell",
            "command": ".\\Scripts\\GenerateProject.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "UE: Open Editor",
            "type": "shell",
            "command": ".\\Scripts\\OpenEditor.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "UE: Clean Build (Delete Binaries + Intermediate)",
            "type": "shell",
            "command": ".\\Scripts\\CleanBuild.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "UE: Cook Game (Windows Shipping)",
            "type": "shell",
            "command": ".\\Scripts\\CookGame.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        }
    ],
    "inputs": [
        {
            "id": "commitMessage",
            "type": "promptString",
            "description": "Describe what you changed (e.g. 'Add ship model', 'Fix player movement')",
            "default": ""
        }
    ]
}
